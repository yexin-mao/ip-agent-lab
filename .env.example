# LLM configuration.
# The project defaults to an OpenAI-compatible chat API. If no API key is set,
# it automatically falls back to rule-based parser/keyword logic.

# Use any OpenAI-compatible chat completions provider.
IP_AGENT_LLM_PROVIDER=openai_compatible

# Examples:
# OpenAI:   https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Local gateway or vLLM: http://localhost:8000/v1
IP_AGENT_LLM_BASE_URL=https://api.openai.com/v1

# Example models:
# OpenAI: gpt-4o-mini, gpt-4.1-mini
# DeepSeek: deepseek-chat
# Qwen-compatible gateway: qwen-plus or provider-specific model name
IP_AGENT_LLM_MODEL=gpt-4o-mini

# Never commit a real key.
IP_AGENT_LLM_API_KEY=replace-with-your-api-key

IP_AGENT_LLM_TIMEOUT=60

# Retrieval backend.
# local: existing local BM25 + hashing-vector hybrid retriever.
# llamaindex: LlamaIndex vector index + BM25 hybrid retriever.
IP_AGENT_RETRIEVER=llamaindex

# Embedding provider used by the LlamaIndex retriever.
# local: deterministic hashing fallback, no API key or model download.
# openai: OpenAI-compatible embedding API.
# bge_m3/huggingface: local HuggingFace embedding model.
IP_AGENT_EMBEDDING_PROVIDER=bge_m3
IP_AGENT_EMBEDDING_MODEL=BAAI/bge-m3

# OpenAI embedding example:
# IP_AGENT_EMBEDDING_PROVIDER=openai
# IP_AGENT_EMBEDDING_MODEL=text-embedding-3-small
# IP_AGENT_EMBEDDING_API_KEY=replace-with-your-api-key
# IP_AGENT_EMBEDDING_BASE_URL=https://api.openai.com/v1

# BGE-M3 example:
# IP_AGENT_EMBEDDING_PROVIDER=bge_m3
# IP_AGENT_EMBEDDING_MODEL=BAAI/bge-m3
